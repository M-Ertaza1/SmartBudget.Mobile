<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartBudget.Mobile.Views.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartBudget.Mobile.ViewModels"
    x:DataType="vm:ForgotPasswordViewModel"
    Title="Forgot Password">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

            <Label Text="Reset your password" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Enter your email and we'll send a reset code."
                   FontSize="14" TextColor="Gray" HorizontalOptions="Center" HorizontalTextAlignment="Center" />

            <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Send reset code" Command="{Binding SendCodeCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>