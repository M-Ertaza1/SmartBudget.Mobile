<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartBudget.Mobile.Views.ResetPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartBudget.Mobile.ViewModels"
    x:DataType="vm:ResetPasswordViewModel"
    Title="Reset Password">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

            <Label Text="Set a new password" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />

            <Entry Placeholder="6-digit code" Keyboard="Numeric" MaxLength="6" Text="{Binding Code}" />
            <Entry Placeholder="New password" IsPassword="True" Text="{Binding NewPassword}" />
            <Entry Placeholder="Confirm new password" IsPassword="True" Text="{Binding ConfirmPassword}" />

            <!-- DEV hint — remove once the real API is wired up -->
            <Label Text="Dev tip: the code is 123456" FontSize="12" TextColor="DarkOrange" HorizontalOptions="Center" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Reset password" Command="{Binding ResetCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>