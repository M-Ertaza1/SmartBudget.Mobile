<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartBudget.Mobile.Views.AddExpensePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SmartBudget.Mobile.ViewModels"
    xmlns:models="clr-namespace:SmartBudget.Mobile.Models"
    x:DataType="vm:AddExpenseViewModel"
    Title="Add Expense">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Amount" FontSize="13" TextColor="Gray" />
            <Entry Placeholder="0.00" Keyboard="Numeric" Text="{Binding Amount}" FontSize="22" />

            <Label Text="Category" FontSize="13" TextColor="Gray" />
            <Picker Title="Choose a category"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}" />

            <Label Text="Date" FontSize="13" TextColor="Gray" />
            <DatePicker Date="{Binding ExpenseDate}" MaximumDate="{Binding MaxDate}" />

            <Label Text="Description (optional)" FontSize="13" TextColor="Gray" />
            <Entry Placeholder="e.g. Lunch with team" Text="{Binding Description}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />

            <Button Text="Save expense" Command="{Binding SaveCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Text="Cancel" Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#512BD4, Dark=#9277E0}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>